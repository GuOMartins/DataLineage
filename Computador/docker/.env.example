# ==============================================================
# .env.example — Template de variáveis de ambiente
# Copie para .env e preencha com seus valores reais
# NUNCA suba o .env para o GitHub
# ==============================================================

# ── OpenLineage ───────────────────────────────────────────────
# URL do backend (Marquez real ou Mock local)
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=datalineage_olist

# ── Projeto ───────────────────────────────────────────────────
# Caminho absoluto para a raiz do projeto
# Exemplo Linux/Mac: /home/usuario/DataLineage
# Exemplo Windows:   C:\Users\usuario\DataLineage
PROJECT_ROOT=/caminho/para/DataLineage

# ── Kaggle ────────────────────────────────────────────────────
# Obtenha em: kaggle.com → Settings → API → Create New Token
KAGGLE_USERNAME=seu_usuario_aqui
KAGGLE_KEY=sua_key_aqui

# ── ngrok (para dashboard no Colab) ──────────────────────────
# Obtenha em: https://dashboard.ngrok.com
NGROK_AUTHTOKEN=seu_token_ngrok_aqui

# ── Marquez Docker (opcional) ────────────────────────────────
MARQUEZ_DB_USER=marquez
MARQUEZ_DB_PASSWORD=marquez
MARQUEZ_DB_NAME=marquez
